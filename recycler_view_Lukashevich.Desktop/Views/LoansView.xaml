<UserControl x:Class="recycler_view_Lukashevich.Views.LoansView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:recycler_view_Lukashevich.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" Width="930">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Foreground="Red" 
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                   HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" KeyDown="SearchTextBox_KeyDown"/>
            <Button Content="🔍 Найти" Width="80" Click="SearchButton_Click"/>
            <Button Content="➕ Новая выдача" Width="100" Click="AddButton_Click"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="↩️ Вернуть" Width="80" Click="ReturnButton_Click"/>
            <Button Content="🔄 Обновить" Width="80" Click="RefreshButton_Click"/>
            <Button Content="📊 Должники" Width="120" Click="DebtorsReport_Click" Margin="5,0,0,0"/>
            <Button Content="📊 Популярные" Width="120" Click="PopularReport_Click" Margin="5,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Загрузка..." HorizontalAlignment="Center" 
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" 
                   FontSize="16" Foreground="Gray"/>
        

        <ListView Grid.Row="3" ItemsSource="{Binding Loans}" SelectedItem="{Binding SelectedLoan}"
                  IsSynchronizedWithCurrentItem="True"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Книга" Width="200" DisplayMemberBinding="{Binding Book.Title}"/>
                    <GridViewColumn Header="Читатель" Width="150" DisplayMemberBinding="{Binding User.FullName}"/>
                    <GridViewColumn Header="Дата выдачи" Width="120" DisplayMemberBinding="{Binding LoanDate}"/>
                    <GridViewColumn Header="Срок возврата" Width="120" DisplayMemberBinding="{Binding DueDate}"/>
                    <GridViewColumn Header="Дата возврата" Width="120" DisplayMemberBinding="{Binding ReturnDate}"/>
                    <GridViewColumn Header="Статус" Width="100" DisplayMemberBinding="{Binding Status}"/>
                    
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>