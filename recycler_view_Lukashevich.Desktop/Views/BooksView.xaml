<UserControl x:Class="recycler_view_Lukashevich.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:recycler_view_Lukashevich.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" KeyDown="SearchTextBox_KeyDown"/>
            <Button Content="🔍 Найти" Width="80" Margin="5,0,0,0" Click="SearchButton_Click"/>
            <Button Content="➕ Добавить" Width="80" Margin="5,0,0,0" Click="AddButton_Click"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="✏️ Редактировать" Width="100" Margin="5,0,0,0" Click="EditButton_Click"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="🗑️ Удалить" Width="80" Margin="5,0,0,0" Click="DeleteButton_Click"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{Binding Books}" SelectedItem="{Binding SelectedBook}"
                  IsSynchronizedWithCurrentItem="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Название" Width="200" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="Автор" Width="150" DisplayMemberBinding="{Binding Author}"/>
                    <GridViewColumn Header="Год" Width="70" DisplayMemberBinding="{Binding Year}"/>
                    <GridViewColumn Header="ISBN" Width="120" DisplayMemberBinding="{Binding ISBN}"/>
                    <GridViewColumn Header="Всего" Width="60" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Доступно" Width="70" DisplayMemberBinding="{Binding AvailableQuantity}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>