<Window x:Class="recycler_view_Lukashevich.Views.AddLoanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая выдача" Height="350" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Книга:" Margin="0,5"/>
        <ComboBox Grid.Row="1" x:Name="BookCombo" Margin="0,5" Padding="5" DisplayMemberPath="Title" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="2" Text="Читатель:" Margin="0,5"/>
        <ComboBox Grid.Row="3" x:Name="UserCombo" Margin="0,5" Padding="5" DisplayMemberPath="FullName" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="4" Text="Срок возврата (дней):" Margin="0,5"/>
        <ComboBox Grid.Row="5" x:Name="DaysCombo" Margin="0,5" Padding="5">
            <ComboBoxItem Content="7 дней" Tag="7" IsSelected="True"/>
            <ComboBoxItem Content="14 дней" Tag="14"/>
            <ComboBoxItem Content="21 день" Tag="21"/>
            <ComboBoxItem Content="30 дней" Tag="30"/>
        </ComboBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Выдать" Width="80" Click="SaveButton_Click" Background="#2196F3" Foreground="White"/>
            <Button Content="Отмена" Width="80" Margin="5,0,0,0" Click="CancelButton_Click" Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>