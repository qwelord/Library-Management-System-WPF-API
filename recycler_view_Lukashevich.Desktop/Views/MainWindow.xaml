<Window x:Class="recycler_view_Lukashevich.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:recycler_view_Lukashevich.Views"
        xmlns:converters="clr-namespace:recycler_view_Lukashevich.Converters"
        Title="{Binding ViewModel.Title}" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📚 Библиотека" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="{Binding ViewModel.CurrentUser}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Выйти" Width="80" Height="30" Margin="5,0" Click="LogoutButton_Click" Background="#E74C3C" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Книги">
                <views:BooksView DataContext="{Binding BooksViewModel}" />
            </TabItem>
            <TabItem Header="Читатели" Visibility="{Binding ViewModel.IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:UsersView DataContext="{Binding UsersViewModel}" />
            </TabItem>
            <TabItem Header="Выдачи">
                <views:LoansView DataContext="{Binding LoansViewModel}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>