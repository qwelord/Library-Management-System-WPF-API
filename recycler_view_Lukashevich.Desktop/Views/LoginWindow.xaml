<Window x:Class="recycler_view_Lukashevich.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:recycler_view_Lukashevich.Converters"
        Title="Авторизация" Height="350" Width="400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔐 Вход в библиотеку" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Email:" Margin="0,5"/>
        <TextBox Grid.Row="2" x:Name="EmailBox" Margin="0,5" Padding="5" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Text="Пароль:" Margin="0,5"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" Margin="0,5" Padding="5"/>

        <Button Grid.Row="5" Content="Войти" Height="40" Margin="0,20"
                Click="LoginButton_Click" Background="#2196F3" Foreground="White"
                FontSize="16" Cursor="Hand" IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>

        <TextBlock Grid.Row="6" x:Name="ErrorText" Foreground="Red"
                   HorizontalAlignment="Center" Visibility="{Binding IsErrorVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                   Text="{Binding ErrorMessage}"/>
    </Grid>
</Window>