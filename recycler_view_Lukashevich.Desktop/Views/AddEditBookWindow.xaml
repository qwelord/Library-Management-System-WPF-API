<Window x:Class="recycler_view_Lukashevich.Views.AddEditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название:" Margin="0,5"/>
        <TextBox Grid.Row="1" x:Name="TitleBox" Margin="0,5" Padding="5" Text="{Binding Title}"/>

        <TextBlock Grid.Row="2" Text="Автор:" Margin="0,5"/>
        <TextBox Grid.Row="3" x:Name="AuthorBox" Margin="0,5" Padding="5" Text="{Binding Author}"/>

        <TextBlock Grid.Row="4" Text="ISBN:" Margin="0,5"/>
        <TextBox Grid.Row="5" x:Name="ISBNBox" Margin="0,5" Padding="5" Text="{Binding ISBN}"/>

        <TextBlock Grid.Row="6" Text="Год издания:" Margin="0,5"/>
        <TextBox Grid.Row="7" x:Name="YearBox" Margin="0,5" Padding="5" Text="{Binding Year}"/>

        <TextBlock Grid.Row="8" Text="Издательство:" Margin="0,5"/>
        <TextBox Grid.Row="9" x:Name="PublisherBox" Margin="0,5" Padding="5" Text="{Binding Publisher}"/>

        <TextBlock Grid.Row="10" Text="Количество:" Margin="0,5"/>
        <TextBox Grid.Row="11" x:Name="QuantityBox" Margin="0,5" Padding="5" Text="{Binding Quantity}"/>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="80" Click="SaveButton_Click" Background="#2196F3" Foreground="White"/>
            <Button Content="Отмена" Width="80" Margin="5,0,0,0" Click="CancelButton_Click" Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>