<Window x:Class="recycler_view_Lukashevich.Views.AddEditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="520" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название:" Margin="0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="1" x:Name="TitleBox" Margin="0,5" Padding="5" 
                 Text="{Binding ViewModel.Title, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBlock Grid.Row="2" Text="Автор:" Margin="0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="3" x:Name="AuthorBox" Margin="0,5" Padding="5" 
                 Text="{Binding ViewModel.Author, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBlock Grid.Row="4" Text="ISBN:" Margin="0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="5" x:Name="ISBNBox" Margin="0,5" Padding="5" 
                 Text="{Binding ViewModel.ISBN, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBlock Grid.Row="6" Text="Год издания:" Margin="0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="7" x:Name="YearBox" Margin="0,5" Padding="5" 
                 Text="{Binding ViewModel.Year, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBlock Grid.Row="8" Text="Издательство:" Margin="0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="9" x:Name="PublisherBox" Margin="0,5" Padding="5" 
                 Text="{Binding ViewModel.Publisher, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBlock Grid.Row="10" Text="Количество:" Margin="0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="11" x:Name="QuantityBox" Margin="0,5" Padding="5" 
                 Text="{Binding ViewModel.Quantity, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Click="SaveButton_Click" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="Отмена" Width="100" Height="35" Margin="10,0,0,0" 
                    Click="CancelButton_Click" Background="#E74C3C" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>